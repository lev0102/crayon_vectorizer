{
  "websocket": {
    "url": "ws://127.0.0.1:8080",
    "connect_on_start": true,
    "reconnect_on_send_failure": true
  },
  "watcher": {
    "recursive": false,
    "debounce_seconds": 0.5,
    "poll_interval_seconds": 1.0,
    "stable_check_interval_seconds": 0.2,
    "stable_checks_required": 3,
    "log_level": "INFO"
  },
  "jpg_watch": {
    "enabled": true,
    "folder": "C:\\Pipeline\\Input",
    "target_file_name": "image00004.jpg",
    "case_sensitive": false,
    "event_type": "input_jpg_ready"
  },
  "spawn_json_watch": {
    "enabled": true,
    "folder": "C:\\Pipeline\\Output",
    "file_regex": "^output_output_.*_vector_spawn_points\\.json$",
    "case_sensitive": false,
    "event_type": "spawn_json_ready"
  }
}