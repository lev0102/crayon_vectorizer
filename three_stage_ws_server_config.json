{
  "websocket_server": {
    "host": "127.0.0.1",
    "port": 8080,
    "log_client_messages": false
  },
  "message_format": {
    "wrap_in_payload": true,
    "envelope_type": "pipeline_event"
  },
  "pipeline_cooldown": {
    "enabled": false,
    "cooldown_seconds": 0.0
  },
  "watcher": {
    "recursive": false,
    "poll_interval_seconds": 1.0,
    "stable_check_interval_seconds": 0.2,
    "stable_checks_required": 3,
    "default_debounce_seconds": 0.5,
    "log_level": "INFO"
  },
  "stage1_source_jpg_watch": {
    "enabled": true,
    "folder": "C:\\Users\\User\\WorkAssets\\DVCY02\\TestFolerOrignalImage",
    "file_regex": "^\\d{4}-\\d{2}-\\d{2}_\\d{2}-\\d{2}-\\d{2}\\.jpg$",
    "case_sensitive": false,
    "event_type": "source_jpg_ready",
    "allowed_events": [
      "created",
      "moved"
    ],
    "queue": {
      "enabled": false,
      "cooldown_seconds": 0.0,
      "deduplicate_by_full_path": true
    }
  },
  "stage2_processed_jpg_watch": {
    "enabled": true,
    "folder": "C:\\Users\\User\\WorkAssets\\DVCY02\\TestFolderModifiedImage",
    "file_regex": "^\\d{4}-\\d{2}-\\d{2}_\\d{2}-\\d{2}-\\d{2}\\.jpg$",
    "case_sensitive": false,
    "allowed_events": [
      "created",
      "moved"
    ],
    "run_pipeline": {
      "enabled": true,
      "python_executable": "",
      "script_path": "run_locked_palette_pipeline.py",
      "config_path": "locked_palette_pipeline_config.json",
      "outdir": "C:\\Users\\User\\Documents\\program\\crayon_vectorizer\\output",
      "extra_args": []
    }
  },
  "stage3_spawn_json_watch": {
    "enabled": true,
    "folder": "C:\\Users\\User\\Documents\\program\\crayon_vectorizer\\output",
    "file_regex": "^output_output_.*_vector_spawn_points\\.json$",
    "case_sensitive": false,
    "event_type": "spawn_json_ready",
    "allowed_events": [
      "created",
      "moved"
    ],
    "queue": {
      "enabled": false,
      "cooldown_seconds": 0.0,
      "deduplicate_by_full_path": true
    }
  },
  "stage3_ack_gate": {
    "enabled": true,
    "ack_message_type": "stage2_ack",
    "match_by": "pipeline_key",
    "fallback_send_after_seconds": 0.0,
    "log_ack_messages": true
  }
}